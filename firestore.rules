rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Validation Blueprint for Transaction
    function isValidTransaction(data) {
      return data.keys().hasAll(['date', 'category', 'description', 'amount', 'userId', 'createdAt'])
        && data.keys().size() <= 10
        && data.date is string && data.date.size() <= 50
        && (data.time == null || (data.time is string && data.time.size() <= 20))
        && data.category is string && data.category.size() <= 50
        && data.description is string && data.description.size() <= 200
        && data.account is string && data.account.size() <= 50
        && data.amount is number
        && (data.icon == null || (data.icon is string && data.icon.size() <= 50))
        && data.userId == request.auth.uid
        && data.createdAt == request.time;
    }

    // 2. Transaction Rules
    match /transactions/{transactionId} {
      // Secure List Queries
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Get single document
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;

      allow create: if isSignedIn() 
        && isValidTransaction(incoming());

      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidTransaction(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['amount', 'description', 'category', 'date', 'time', 'account', 'icon']);

      allow delete: if isSignedIn() 
        && isOwner(existing().userId);
    }
  }
}
