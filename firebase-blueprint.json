{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction record",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "time": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "account": { "type": "string" },
        "amount": { "type": "number" },
        "icon": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "category", "description", "amount", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User transactions collection"
    }
  }
}
